socket.on('modbusData', function (data) {

    console.log("Data:", data);

    globarr = data;

    console.log("globarr.status =", globarr.status);
    console.log("newcycle =", newcycle);

    if (globarr.status === "0" && newcycle === 0) {

        console.log("Status 0 received -> New Cycle Started");

        newcycle = 1;
        clearFields();
    }

    else if (globarr.status === "1" && newcycle === 1) {

        console.log("Status 1 received -> Displaying Values");

        document.getElementById('forceValue').innerText =
            globarr.force ? parseFloat(globarr.force).toFixed(3) : '';

        document.getElementById('loadValue').innerText =
            globarr.load ? parseFloat(globarr.load).toFixed(3) : '';

        document.getElementById('bitValue').innerText = 'OK';

        document.getElementById("bitValue").style.backgroundColor = "green";
        document.getElementById("bitValue1").style.backgroundColor = "green";
    }

    else if (globarr.status === "2") {

        console.log("Status 2 received -> NOK");

        document.getElementById('forceValue').innerText =
            globarr.force ? parseFloat(globarr.force).toFixed(3) : '';

        document.getElementById('loadValue').innerText =
            globarr.load ? parseFloat(globarr.load).toFixed(3) : '';

        document.getElementById('bitValue').innerText = 'NOK';

        document.getElementById("bitValue").style.backgroundColor = "red";
        document.getElementById("bitValue1").style.backgroundColor = "red";
    }

    else {

        console.log("Else Block Executed");
        console.log("status =", globarr.status);
        console.log("newcycle =", newcycle);

        clearFields();
    }
});
