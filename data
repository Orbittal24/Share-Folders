io.on("connection", (socket) => {

    console.log("Client Connected :", socket.id);

    socket.on("shift_to_mirror", async () => {

        try {

            // Fetch all records
            const result = await dbConn.request().query(`
                SELECT
                    sr_no,
                    cell_qrcode,
                    voltage,
                    ir,
                    today_date,
                    updated_time,
                    machine_location,
                    shift,
                    used_on_line,
                    kvalue,
                    grade,
                    cell_capacity,
                    cell_class
                FROM taco_treceability.ocv_machine_data_mirror_rejection
                ORDER BY sr_no
            `);

            const rows = result.recordset;

            if (rows.length === 0) {

                socket.emit("shift_completed", {
                    success: true,
                    total: 0
                });

                return;
            }

            let shiftedCount = 0;

            // Shift records one by one
            for (const row of rows) {

                try {

                    // Insert exact record into mirror table
                    const insertResult = await dbConn.request().query(`
                        INSERT INTO taco_treceability.ocv_machine_data_mirror_testing
                        (
                            sr_no,
                            cell_qrcode,
                            voltage,
                            ir,
                            today_date,
                            updated_time,
                            machine_location,
                            shift,
                            used_on_line,
                            kvalue,
                            grade,
                            cell_capacity,
                            cell_class
                        )

                        SELECT
                            sr_no,
                            cell_qrcode,
                            voltage,
                            ir,
                            today_date,
                            updated_time,
                            machine_location,
                            shift,
                            used_on_line,
                            kvalue,
                            grade,
                            cell_capacity,
                            cell_class
                        FROM taco_treceability.ocv_machine_data_mirror_rejection
                        WHERE sr_no = ${row.sr_no}
                    `);

                    // Check acknowledgement from SQL Server
                    if (insertResult.rowsAffected[0] > 0) {

                        // Delete only after successful insert
                        const deleteResult = await dbConn.request().query(`
                            DELETE
                            FROM taco_treceability.ocv_machine_data_mirror_rejection
                            WHERE sr_no = ${row.sr_no}
                        `);

                        if (deleteResult.rowsAffected[0] > 0) {

                            shiftedCount++;

                            socket.emit("shift_progress", {
                                shifted: shiftedCount,
                                total: rows.length
                            });

                            console.log(
                                `Shifted SR NO : ${row.sr_no}`
                            );
                        }
                    }

                } catch (err) {

                    console.log(
                        `Error shifting SR NO : ${row.sr_no}`,
                        err.message
                    );
                }
            }

            socket.emit("shift_completed", {
                success: true,
                total: shiftedCount
            });

        } catch (err) {

            console.log("Shift Error :", err);

            socket.emit("shift_completed", {
                success: false,
                message: err.message
            });
        }
    });

    socket.on("disconnect", () => {
        console.log("Client Disconnected :", socket.id);
    });

});


