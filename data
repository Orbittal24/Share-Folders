# -----------------------------------
# CONNECT DB
# -----------------------------------
def connect_db(config):
    conn = pyodbc.connect(
        f"DRIVER={{ODBC Driver 17 for SQL Server}};"
        f"SERVER={config['server']};"
        f"DATABASE={config['database']};"
        f"UID={config['user']};"
        f"PWD={config['password']};"
        f"TrustServerCertificate=yes;"
    )
    conn.autocommit = False
    return conn

# -----------------------------------
# LOG FUNCTION
# -----------------------------------
def log_event(cursor, cellqr, stage, status, message=""):
    cursor.execute("""
        IF NOT EXISTS (
            SELECT 1 FROM INFORMATION_SCHEMA.TABLES 
            WHERE TABLE_NAME = 'ocv_process_log'
        )
        BEGIN
            CREATE TABLE ocv_process_log (
                id INT IDENTITY(1,1) PRIMARY KEY,
                cellqr NVARCHAR(100),
                stage NVARCHAR(50),
                status NVARCHAR(20),
                message NVARCHAR(MAX),
                log_time DATETIME DEFAULT GETDATE()
            )
        END
    """)

    cursor.execute("""
        INSERT INTO ocv_process_log (cellqr, stage, status, message)
        VALUES (?, ?, ?, ?)
    """, (cellqr, stage, status, message))

