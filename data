let lastForce = null;

socket.on('modbusData', function (data) {

    console.log("Data:", data);

    globarr = data;

    let currentForce = parseFloat(globarr.force);

    console.log("lastForce:", lastForce);
    console.log("currentForce:", currentForce);

    // First value received
    if (lastForce === null) {

        document.getElementById('forceValue').innerText =
            currentForce.toFixed(3);

        document.getElementById('loadValue').innerText =
            globarr.load || '';

        document.getElementById('bitValue').innerText = 'OK';

        document.getElementById("bitValue").style.backgroundColor = "green";
        document.getElementById("bitValue1").style.backgroundColor = "green";

        lastForce = currentForce;

        return;
    }

    // Update only when force changes
    if (currentForce !== lastForce) {

        console.log("Force Changed:", lastForce, "=>", currentForce);

        document.getElementById('forceValue').innerText =
            currentForce.toFixed(3);

        document.getElementById('loadValue').innerText =
            globarr.load || '';

        document.getElementById('bitValue').innerText = 'OK';

        document.getElementById("bitValue").style.backgroundColor = "green";
        document.getElementById("bitValue1").style.backgroundColor = "green";

        // Store latest force value
        lastForce = currentForce;
    }
});




lastForce = null;
