# -----------------------------------
# ERROR TYPES
# -----------------------------------
class DataValidationError(Exception):
    """Raised when the record itself is malformed (bad QR, bad date code)."""
    pass

class TransientError(Exception):
    """Raised on SQL/Redis/connection failures that are not the record's fault."""
    pass

# -----------------------------------
# SAFE STRING
# -----------------------------------
def safe(val):
    return "" if val is None else str(val)

def extract_capacity(val):
    if val is None:
        return ""

    val_str = str(val)
    match = re.search(r"\d+(\.\d+)?", val_str)

    if match:
        return match.group(0)

    return ""

