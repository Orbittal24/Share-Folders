<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>OCV Reject Data</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f5f5f5;
        }

        h1 {
            text-align: center;
        }

        .top-section {
            text-align: center;
            margin-bottom: 20px;
        }

        button {
            padding: 12px 40px;
            font-size: 18px;
            cursor: pointer;
            border: none;
            border-radius: 5px;
            background: #007bff;
            color: white;
        }

        button:hover {
            background: #0056b3;
        }

        #totalCount {
            margin-top: 15px;
            font-size: 22px;
            font-weight: bold;
            color: green;
        }

        .table-container {
            width: 100%;
            overflow-x: auto;
