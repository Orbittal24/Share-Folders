                <option value="SM eDost">
                <option value="NOVA MROPS">
                <option value="NOVA LROPS">
                <option value="CORAL SR">
                <option value="Kratos1 450kwh">
                <option value="EBUS LR">
                <option value="TVS 9">
                <option value="Tamor">
                <option value="Bajaj 12.1">
                <option value="EBUS 283">
                <option value="Cerus1 Cerus2 Kratos HD 450kwh">
                <option value="Kratos1 300kwh">
                <option value="Cerus1 Cerus2 300kwh">
                <option value="UPP 39.9">
                <option value="UPP 27.8">
                <option value="Bajaj 5.9">
                <option value="Bajaj 9.2">
                <option value="Bajaj 12.2">
                <option value="EBUS 424">
                <option value="Challenger LR">
                <option value="Challenger MR">
