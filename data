socket.on('get_modbusData', function () {

    console.log(
        "Current Registers:",
        globarr
    );

    if (
        !globarr ||
        globarr.length < 32
    ) {
        return;
    }

    let longValues = [];

    for (
        let i = 0;
        i < globarr.length;
        i += 2
    ) {

        longValues.push(
            convertLongIntegerLSW(
                globarr[i],
                globarr[i + 1]
            )
        );
    }

    console.log(
        "Converted Long Values:",
        longValues
    );

    /*
      Register Mapping Example

      LongValue[0] = Reg1 + Reg2
      LongValue[1] = Reg3 + Reg4
      LongValue[2] = Reg5 + Reg6
      ...
    */

    // Change index according to PLC mapping
    let force = longValues[1];
    let loadValue = longValues[4];
    let bitvalue = longValues[6];

    let finalValue =
        (0.001 * force) +
        851.968;

    socket.emit(
        "modbusData",
        {
            force: finalValue,
            load: loadValue,
            status: bitvalue
        }
    );

    console.log(
        "Data sent:",
        {
            force: finalValue,
            load: loadValue,
            status: bitvalue
        }
    );
});
