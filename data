                <option value="PDU EBUS 184">
                <option value="Bajaj 9.2 LL">
                <option value="Bajaj 12.1 LL">
                <option value="TVS 12.1">
            </datalist>
        </div>

        <div class="group line">
            <label>Pack No :</label>
            <input 
                type="text" 
                id="packNo" 
                name="pack_no"
                placeholder="Enter 6 digit Pack No"
                maxlength="6"
                pattern="\d{6}"
                inputmode="numeric"
                required
            >
        </div>

        <div class="group barcode">
            <label>Smoke Sensor :</label>
            <input type="text" id="barcode"
                placeholder="Scan Barcode"
                autocomplete="off"
                inputmode="none"
                autofocus>
        </div>
    </div>

    <div class="button-row">
        <button onclick="submitData()">Submit</button>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io("http://localhost:5401"); // make sure port matches backend

socket.on("connect", () => {
    console.log("Connected to backend, ID:", socket.id);
});

function submitData() {
    const packName = document.getElementById("stationName").value.trim();
    const packNo = document.getElementById("packNo").value.trim();
    let barcode = document.getElementById("barcode").value.trim();

    if(!packName){
        alert("Please select Pack Name");
        return;
    }

    if(!/^\d{6}$/.test(packNo)){
        alert("Pack No must be exactly 6 digits");
        return;
    }

    if(!barcode) barcode = "na";

    const data = { pack_name: packName, pack_no: packNo, smoke_sensor: barcode };
    console.log("Sending data:", data);
    socket.emit("submitPackData", data);
}

socket.on("packResponse", (status, message) => {
    alert(message);
    if(status === "success"){
        document.getElementById("packNo").value = "";
        document.getElementById("barcode").value = "";
        document.getElementById("stationName").value = "";
        document.getElementById("stationName").focus();
    }
});

socket.on("setProcess", (moduleBarcode, moduleNumber) => {
    console.log("Module Info:", moduleBarcode, moduleNumber);
});
</script>

</body>
</html>



