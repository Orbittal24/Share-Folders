# -----------------------------------
# ENSURE TABLE
# -----------------------------------
def ensure_table(dst_cursor, tableName):
    dst_cursor.execute(f"""
    IF NOT EXISTS (
        SELECT 1 FROM INFORMATION_SCHEMA.TABLES
        WHERE TABLE_NAME = '{tableName}'
    )
    BEGIN
        CREATE TABLE {tableName} (
            sr_no INT IDENTITY(1,1) PRIMARY KEY,
            cellqr NVARCHAR(50),
            voltage NVARCHAR(50),
            ir NVARCHAR(50),
            class_grade NVARCHAR(30),
            capacity NVARCHAR(50),
            thickness NVARCHAR(50),
            k_value NVARCHAR(50),
            negative_voltage NVARCHAR(50),
            cell_status NVARCHAR(20),
            ocv_mc_no NVARCHAR(40),
            first_para_time DATETIME,
            last_para_time DATETIME,
            laser_status VARCHAR(50),
            batch VARCHAR(100),
            plant_code VARCHAR(50)
        )
    END
    """)

# -----------------------------------
# ENSURE REJECTION TABLE HAS AUDIT COLUMNS
# -----------------------------------
def ensure_rejection_columns(src_cursor):
    src_cursor.execute("""
    IF NOT EXISTS (
        SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS
        WHERE TABLE_NAME='ocv_machine_data_mirror_rejection' AND COLUMN_NAME='reject_reason'
    )
    BEGIN
        ALTER TABLE taco_treceability.ocv_machine_data_mirror_rejection
        ADD reject_reason NVARCHAR(200) NULL, retry_count INT NULL, rejected_at DATETIME NULL
    END
    """)

# -----------------------------------
# MOVE TO REJECTION
# -----------------------------------
def move_to_rejection(src_conn, row, reason, retry_count):
    cursor = src_conn.cursor()
    try:
        cursor.execute("""
        INSERT INTO taco_treceability.ocv_machine_data_mirror_rejection
        (
            cell_qrcode, voltage, ir, today_date, updated_time,
            machine_location, shift, used_on_line, kvalue,
            grade, cell_capacity, cell_class,
            reject_reason, retry_count, rejected_at
        )
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,GETDATE())
        """,
        (
            row.cell_qrcode,
            row.voltage,
            row.ir,
            row.today_date,
            row.updated_time,
            row.machine_location,
            row.shift,
            row.used_on_line,
            row.kvalue,
            row.grade,
            row.cell_capacity,
            row.cell_class,
            reason,
            retry_count
        ))

        src_conn.commit()
        print("MOVED TO REJECTION :", row.cell_qrcode, "| reason:", reason)
        return True

    except Exception as e:
        print("REJECTION INSERT FAILED :", e)
        src_conn.rollback()
        return False

# -----------------------------------
# HANDLE FAILURE (RETRY LOGIC, SPLIT BY ERROR TYPE)
# -----------------------------------
def handle_failure(src_conn, row, error):
    qr = safe(row.cell_qrcode)
    retry_key = RETRY_KEY_PREFIX + qr

    is_data_error = isinstance(error, DataValidationError)
    reason = str(error)

    try:
        retry_count = r.get(retry_key)
        retry_count = int(retry_count) if retry_count else 0

        if is_data_error:
            # Genuine bad record — counts toward MAX_RETRY
            retry_count += 1

            if retry_count >= MAX_RETRY:
                print(f"MAX RETRY REACHED ({retry_count}) :", qr, "| reason:", reason)

                if move_to_rejection(src_conn, row, reason, retry_count):
                    cursor = src_conn.cursor()
                    cursor.execute("""
                    DELETE FROM taco_treceability.ocv_machine_data_mirror
                    WHERE cell_qrcode=?
                    """, qr)

                    src_conn.commit()
                    print("DELETED AFTER REJECTION :", qr)

                    r.delete(retry_key)

            else:
                r.setex(retry_key, 3600, retry_count)
                print(f"DATA ERROR RETRY {retry_count}/{MAX_RETRY} :", qr, "| reason:", reason)

        else:
            # Transient/infra error — does NOT count toward rejection.
            # Record stays untouched in source; just log + track for monitoring.
            print("TRANSIENT ERROR (not counted toward rejection) :", qr, "| reason:", reason)

            transient_key = "transient_fail:" + qr
            t_count = r.incr(transient_key)
            r.expire(transient_key, 3600)
            if t_count >= 10:
                print(f"WARNING: {qr} has failed {t_count} times due to transient errors — investigate DB/Redis health")

    except Exception as e:
        print("RETRY HANDLER ERROR :", e)

# -----------------------------------
# PARSE DATE CODE (case-insensitive, with diagnostics)
# -----------------------------------
def parse_date_code(qr):
    code12_13 = qr[12:14].upper()
    dateCode_raw = qr[8:11] if code12_13 == "BV" else qr[14:17]
    dateCode = dateCode_raw.upper()

    if len(dateCode) < 3:
        raise DataValidationError(f"dateCode too short: '{dateCode_raw}' (qr={qr})")

    yearValue = yearMap.get(dateCode[0])
    monthValue = monthMap.get(dateCode[1])
    dayValue = dayMap.get(dateCode[2])

    if not yearValue or not monthValue or not dayValue:
        raise DataValidationError(
            f"date mapping failed: dateCode='{dateCode_raw}' "
            f"(year_char='{dateCode[0]}'->{yearValue}, "
            f"month_char='{dateCode[1]}'->{monthValue}, "
            f"day_char='{dateCode[2]}'->{dayValue}) qr={qr}"
        )

    return dateCode, code12_13, yearValue, monthValue, dayValue

# -----------------------------------
# PROCESS RECORD
# -----------------------------------
def process_record(src_conn, dst_conn):

    src_cursor = src_conn.cursor()
    dst_cursor = dst_conn.cursor()

    row = None

    try:
        try:
            src_cursor.execute("""
            SELECT TOP 1 *
            FROM taco_treceability.ocv_machine_data_mirror
            WHERE machine_location='line3_line4'
            ORDER BY sr_no ASC
            """)
            row = src_cursor.fetchone()
        except Exception as e:
            raise TransientError(f"source select failed: {e}")

        if not row:
            print("No records...")
            return

        qr = safe(row.cell_qrcode)

        print("\n========= NEW RECORD =========")
        print("QR :", qr)

        if len(qr) < 16:
            raise DataValidationError(f"QR too short: {qr}")

        dateCode, code12_13, yearValue, monthValue, dayValue = parse_date_code(qr)

        year = 2000 + yearValue
        month = f"{monthValue:02d}"
        day = f"{dayValue:02d}"

        tableName = f"ocvcell_inventory_data_{year}_{month}_{day}"

        print("TABLE :", tableName)

        try:
            ensure_table(dst_cursor, tableName)
        except Exception as e:
            raise TransientError(f"ensure_table failed: {e}")

        capacity_val = extract_capacity(row.cell_capacity)

        try:
            dst_cursor.execute(f"SELECT cellqr FROM {tableName} WHERE cellqr=?", qr)
            exists = dst_cursor.fetchone()

            if exists:
                dst_cursor.execute(f"""
                UPDATE {tableName}
                SET voltage=?, ir=?, class_grade=?, capacity=?,
                    k_value=?, ocv_mc_no=?, first_para_time=?,
                    last_para_time=?, batch=?, plant_code=?
                WHERE cellqr=?
                """,
                (
                    safe(row.voltage),
                    safe(row.ir),
                    safe(row.cell_class),
                    capacity_val,
                    safe(row.kvalue),
                    safe(row.machine_location),
                    row.today_date,
                    row.today_date,
                    dateCode,
                    code12_13,
                    qr
                ))
                print("UPDATED :", qr)

            else:
                dst_cursor.execute(f"""
                INSERT INTO {tableName}
                (cellqr, voltage, ir, class_grade, capacity, thickness,
                 k_value, negative_voltage, cell_status, ocv_mc_no,
                 first_para_time, last_para_time, laser_status, batch, plant_code)
                VALUES (?,?,?,?,?,NULL,?,NULL,'OK',?,?,?,NULL,?,?)
                """,
                (
                    qr,
                    safe(row.voltage),
                    safe(row.ir),
                    safe(row.cell_class),
                    capacity_val,
                    safe(row.kvalue),
                    safe(row.machine_location),
                    row.today_date,
                    row.today_date,
                    dateCode,
                    code12_13
                ))
                print("INSERTED :", qr)

            dst_conn.commit()
            print("SQL SUCCESS :", qr)

        except Exception as sql_error:
            print("SQL FAILED :", sql_error)
            dst_conn.rollback()
            raise TransientError(f"destination SQL failed: {sql_error}")

        # REDIS
        try:
            redis_payload = {
                "cellqr": qr,
                "voltage": safe(row.voltage),
                "ir": safe(row.ir),
                "class_grade": safe(row.cell_class),
                "capacity": capacity_val,
                "k_value": safe(row.kvalue),
                "ocv_mc_no": safe(row.machine_location),
                "first_para_time": str(row.today_date),
                "last_para_time": str(row.today_date),
                "batch": dateCode,
                "plant_code": code12_13
            }

            r.setex(f"cell:{qr}", DUPLICATE_TTL_SECONDS, json.dumps(redis_payload))

            print("REDIS SUCCESS :", redis_payload)

        except Exception as redis_error:
            # Record is already committed to dst SQL — don't reject it.
            # Redis is a cache layer, not source of truth, so log and continue
            # so the source row still gets deleted below.
            print("REDIS FAILED (non-fatal, record already persisted) :", redis_error)

        # DELETE FROM SOURCE
        try:
            src_cursor.execute("""
            DELETE FROM taco_treceability.ocv_machine_data_mirror
            WHERE cell_qrcode=?
            """, qr)

            src_conn.commit()
            print("SOURCE DELETED :", qr)

        except Exception as del_error:
            src_conn.rollback()
            raise TransientError(f"source delete failed: {del_error}")

    except DataValidationError as e:
        print("DATA VALIDATION ERROR :", e)
        if row:
            handle_failure(src_conn, row, e)

    except TransientError as e:
        print("TRANSIENT ERROR :", e)
        if row:
            handle_failure(src_conn, row, e)
        # back off before hitting the same row again instead of hammering it
        time.sleep(1.0)

    except Exception as e:
        # Unclassified — treat conservatively as transient so we never
        # wrongly reject a record we don't understand the failure mode for
        print("UNEXPECTED ERROR (treated as transient) :", e)
        if row:
            handle_failure(src_conn, row, TransientError(str(e)))
        time.sleep(1.0)

# -----------------------------------
# MAIN LOOP
# -----------------------------------
def start():
    src_conn = connect_db(sqlConfig1)
    dst_conn = connect_db(sqlConfig2)

    try:
        ensure_rejection_columns(src_conn.cursor())
        src_conn.commit()
    except Exception as e:
        print("ENSURE REJECTION COLUMNS FAILED :", e)
        src_conn.rollback()

    print("SYSTEM STARTED")

    while True:
        try:
            process_record(src_conn, dst_conn)

        except Exception as main_error:
            print("MAIN LOOP ERROR :", main_error)

            try:
                src_conn = connect_db(sqlConfig1)
                dst_conn = connect_db(sqlConfig2)
                print("DB RECONNECTED")
            except:
                print("RECONNECT FAILED")

        time.sleep(0.1)

# -----------------------------------
# START
# -----------------------------------
start()
