<body>

    <h1>OCV Rejection Records</h1>

    <div class="top-section">
        <button onclick="loadData()">Scan</button>

        <div id="totalCount">
            Total Records : 0
        </div>

        <div id="loading"></div>
    </div>

    <div class="table-container">

        <table>

            <thead>
                <tr>
                    <th>Sr No</th>
                    <th>Cell QR Code</th>
                    <th>Voltage</th>
                    <th>IR</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Machine Location</th>
                    <th>Shift</th>
                    <th>Used On Line</th>
                    <th>K Value</th>
                    <th>Grade</th>
                    <th>Capacity</th>
                    <th>Class</th>
                </tr>
            </thead>

            <tbody id="tableBody">

            </tbody>

        </table>

    </div>

    <script>

        async function loadData() {

            document.getElementById("loading").innerHTML = "Loading Data...";
            document.getElementById("tableBody").innerHTML = "";

            try {

                const response = await fetch("/api/get_ocv_reject_data");
                const result = await response.json();

                document.getElementById("loading").innerHTML = "";

                if (!result.success) {
                    alert("Unable to fetch data");
                    return;
                }

                document.getElementById("totalCount").innerHTML =
                    "Total Records : " + result.totalCount;

                let html = "";

                result.data.forEach((row, index) => {

                    html += `
                        <tr>
                            <td>${index + 1}</td>
                            <td>${row.cell_qrcode || ""}</td>
                            <td>${row.voltage || ""}</td>
                            <td>${row.ir || ""}</td>
                            <td>${formatDate(row.today_date)}</td>
                            <td>${row.updated_time || ""}</td>
                            <td>${row.machine_location || ""}</td>
                            <td>${row.shift || ""}</td>
                            <td>${row.used_on_line || ""}</td>
                            <td>${row.kvalue || ""}</td>
                            <td>${row.grade || ""}</td>
                            <td>${row.cell_capacity || ""}</td>
                            <td>${row.cell_class || ""}</td>
                        </tr>
                    `;
                });

                document.getElementById("tableBody").innerHTML = html;

            } catch (err) {

                console.log(err);

                document.getElementById("loading").innerHTML =
                    "Error while loading data";
            }
        }

        function formatDate(dateStr) {

            if (!dateStr) return "";

            const d = new Date(dateStr);

            return d.toLocaleDateString("en-GB");
        }

    </script>

</body>

</html>
