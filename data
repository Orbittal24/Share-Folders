import re

def extract_capacity(val):
    if val is None:
        return ""

    val_str = str(val)

    # Extract first number (integer or decimal)
    match = re.search(r"\d+(\.\d+)?", val_str)

    if match:
        return match.group(0)   # returns "105" from "105 AH"
    
    return ""
