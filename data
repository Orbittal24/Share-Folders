socket.on('modbusData', function (data) {

    console.log("Data:", data);

    globarr = data;

    // Always show latest values
    document.getElementById('forceValue').innerText =
        data.force !== undefined
            ? parseFloat(data.force).toFixed(3)
            : '';

    document.getElementById('loadValue').innerText =
        data.load !== undefined
            ? data.load
            : '';

    // Status handling
    if (data.status === "1") {

        document.getElementById('bitValue').innerText = 'OK';

        document.getElementById("bitValue").style.backgroundColor = "green";
        document.getElementById("bitValue1").style.backgroundColor = "green";

        console.log("Values Displayed");

    }
    else if (data.status === "0") {

        document.getElementById('bitValue').innerText = 'WAIT';

        document.getElementById("bitValue").style.backgroundColor = "yellow";
        document.getElementById("bitValue1").style.backgroundColor = "yellow";

        console.log("Waiting for cycle");

    }
    else if (data.status === "2") {

        document.getElementById('bitValue').innerText = 'NOK';

        document.getElementById("bitValue").style.backgroundColor = "red";
        document.getElementById("bitValue1").style.backgroundColor = "red";

        console.log("NOK Status");

    }
    else {

        document.getElementById('bitValue').innerText = data.status;

        console.log("Unknown Status:", data.status);
    }
});





