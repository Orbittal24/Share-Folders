const express = require("express");
const sql = require("mssql");
const path = require("path");
const http = require("http");
const { Server } = require("socket.io");

const app = express();
const server = http.createServer(app);
const io = new Server(server);

// ================= DATABASE CONFIG =================
const sqlConfig = {
    user: "user_mis",
    password: "admin@123",
    database: "taco_treceability",
    server: "10.9.4.29",
    port: 1433,
    options: {
        instanceName: "PROD_SQL_2026",
        encrypt: false,
        trustServerCertificate: true
    },
    pool: {
        max: 10,
        min: 0,
        idleTimeoutMillis: 30000
    }
};

// ================= CONNECT DATABASE =================
let dbConn;

async function connectDB() {
    try {
        dbConn = await sql.connect(sqlConfig);
        console.log("✅ SQL Server Connected");
    } catch (err) {
        console.log("❌ Database Connection Error:", err);
    }
}

connectDB();

// ================= ROUTES =================

app.get("/OCV_reject", (req, res) => {
    res.sendFile(path.join(__dirname, "OCV_reject.html"));
});

// Existing API for loading records
app.get("/api/get_ocv_reject_data", async (req, res) => {

    try {

        const result = await dbConn.request().query(`
            SELECT
                sr_no,
                cell_qrcode,
                voltage,
                ir,
                today_date,
                updated_time,
                machine_location,
                shift,
                used_on_line,
                kvalue,
                grade,
                cell_capacity,
                cell_class
            FROM taco_treceability.ocv_machine_data_mirror_rejection
            ORDER BY sr_no
        `);

        res.json({
            success: true,
            totalCount: result.recordset.length,
            data: result.recordset
        });

    } catch (err) {

        console.log(err);

        res.json({
            success: false,
            message: err.message
        });
    }
});

// ================= SOCKET.IO =================

io.on("connection", (socket) => {

    console.log("Client Connected :", socket.id);

    // SHIFT DATA
    socket.on("shift_to_mirror", async () => {

        try {

            // Fetch all records
            const result = await dbConn.request().query(`
                SELECT
                    sr_no,
                    cell_qrcode,
                    voltage,
                    ir,
                    today_date,
                    updated_time,
                    machine_location,
                    shift,
                    used_on_line,
                    kvalue,
                    grade,
                    cell_capacity,
                    cell_class
                FROM taco_treceability.ocv_machine_data_mirror_rejection
                ORDER BY sr_no
            `);

            const rows = result.recordset;

            if (rows.length === 0) {

                socket.emit("shift_completed", {
                    success: true,
                    total: 0
                });

                return;
            }

            let shiftedCount = 0;

            // Shift records one by one
            for (const row of rows) {

                try {

                    // INSERT
                    const insertResult = await dbConn.request()
                        .input("cell_qrcode", sql.VarChar, row.cell_qrcode)
                        .input("voltage", sql.Float, row.voltage)
                        .input("ir", sql.Float, row.ir)
                        .input("today_date", sql.VarChar, row.today_date)
                        .input("updated_time", sql.VarChar, row.updated_time)
                        .input("machine_location", sql.VarChar, row.machine_location)
                        .input("shift", sql.VarChar, row.shift)
                        .input("used_on_line", sql.VarChar, row.used_on_line)
                        .input("kvalue", sql.VarChar, row.kvalue)
                        .input("grade", sql.VarChar, row.grade)
                        .input("cell_capacity", sql.VarChar, row.cell_capacity)
                        .input("cell_class", sql.VarChar, row.cell_class)
                        .query(`
                            INSERT INTO taco_treceability.ocv_machine_data_mirror_testing
                            (
                                cell_qrcode,
                                voltage,
                                ir,
                                today_date,
                                updated_time,
                                machine_location,
                                shift,
                                used_on_line,
                                kvalue,
                                grade,
                                cell_capacity,
                                cell_class
                            )
                            VALUES
                            (
                                @cell_qrcode,
                                @voltage,
                                @ir,
                                @today_date,
                                @updated_time,
                                @machine_location,
                                @shift,
                                @used_on_line,
                                @kvalue,
                                @grade,
                                @cell_capacity,
                                @cell_class
                            )
                        `);

                    // ACKNOWLEDGEMENT
                    if (insertResult.rowsAffected[0] > 0) {

                        // DELETE ONLY AFTER SUCCESSFUL INSERT
                        await dbConn.request()
                            .input("sr_no", sql.Int, row.sr_no)
                            .query(`
                                DELETE
                                FROM taco_treceability.ocv_machine_data_mirror_rejection
                                WHERE sr_no=@sr_no
                            `);

                        shiftedCount++;

                        socket.emit("shift_progress", {
                            shifted: shiftedCount,
                            total: rows.length
                        });
                    }

                } catch (err) {

                    console.log(
                        "Error shifting SR NO:",
                        row.sr_no,
                        err.message
                    );
                }
            }

            socket.emit("shift_completed", {
                success: true,
                total: shiftedCount
            });

        } catch (err) {

            console.log(err);

            socket.emit("shift_completed", {
                success: false
            });
        }
    });

    socket.on("disconnect", () => {
        console.log("Client Disconnected :", socket.id);
    });

});

// ================= START SERVER =================

server.listen(5510, "0.0.0.0", () => {

    console.log("=====================================");
    console.log("Server Running On Port 5510");
    console.log("http://localhost:5510/OCV_reject");
    console.log("=====================================");
});




