socket.on("getProcess", function(New_final_qr_code, pack_name){

    var moduleBarcode = "";
    var moduleNumber = "";

    var processquery = `
    SELECT ModuleBarcode, moduleNumber 
    FROM taco_treceability.station_status 
    WHERE FinalQRCode LIKE '%${New_final_qr_code}%' 
    AND PackName='${pack_name}'
    `;

    sql.connect(sqlConfig, function (err) {  

        if (err) {
            console.log(err);
            return;
        }

        request = new sql.Request();

        request.query(processquery, function (err, recordset) {

            if (err) {
                console.log(err);
                return;
            }

            var result1 = recordset.recordset;

            if (result1.length > 0) {

                for (var i = 0; i < result1.length; i++) {

                    moduleBarcode = result1[i].ModuleBarcode;
                    moduleNumber = result1[i].moduleNumber;

                }

                socket.emit("setProcess", moduleBarcode, moduleNumber);

            } 
            else {

                socket.emit("setProcess", "NA", "No Data Found");

            }

        });

    });

});
